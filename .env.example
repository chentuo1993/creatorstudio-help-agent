AI_BUILDER_TOKEN=your_token_here

AI_BUILDERS_BASE_URL=https://space.ai-builders.com/backend/v1

EMBEDDING_MODEL=text-embedding-3-small
RERANK_MODEL=deepseek
ANSWER_MODEL=grok-4-fast

ENABLE_RERANK=true
RETRIEVE_TOP_K=40
ANSWER_TOP_K=5

# Set to true to skip LLM rerank and use smaller K (faster, less precise).
PERF_MODE=false

DB_PATH=data/index.db

LOG_LEVEL=info
